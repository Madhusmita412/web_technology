{
  "version": 2,
  "builds": [
    {
      "src": "api/*.php",
      "use": "@vercel/php"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/web_technology/lab8/index.php",
      "dest": "/api/lab_exp8.php"
    },
    {
      "src": "/lab8/index.php",
      "dest": "/api/lab_exp8.php"
    },
    {
      "src": "/web_technology/lab8/?",
      "dest": "/api/lab_exp8.php"
    },
    {
      "src": "/lab8/?",
      "dest": "/api/lab_exp8.php"
    },
    {
      "src": "/web_technology/lab9/index.php",
      "dest": "/api/lab_exp9.php"
    },
    {
      "src": "/lab9/index.php",
      "dest": "/api/lab_exp9.php"
    },
    {
      "src": "/web_technology/lab9/?",
      "dest": "/api/lab_exp9.php"
    },
    {
      "src": "/lab9/?",
      "dest": "/api/lab_exp9.php"
    },
    {
      "src": "/web_technology/lab10/index.php",
      "dest": "/api/lab_exp10_index.php"
    },
    {
      "src": "/lab10/index.php",
      "dest": "/api/lab_exp10_index.php"
    },
    {
      "src": "/web_technology/lab10/products.php",
      "dest": "/api/lab_exp10_products.php"
    },
    {
      "src": "/lab10/products.php",
      "dest": "/api/lab_exp10_products.php"
    },
    {
      "src": "/web_technology/lab10/cart.php",
      "dest": "/api/lab_exp10_cart.php"
    },
    {
      "src": "/lab10/cart.php",
      "dest": "/api/lab_exp10_cart.php"
    },
    {
      "src": "/web_technology/lab10/?",
      "dest": "/api/lab_exp10_index.php"
    },
    {
      "src": "/lab10/?",
      "dest": "/api/lab_exp10_index.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/web_technology/(.*)",
      "dest": "/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
